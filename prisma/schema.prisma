generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  name      String
  email     String?  @unique
  kelas     String
  jurusan   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  borrows Borrow[]
  users   User[]
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  borrows Borrow[]
}

model Borrow {
  id_borrow Int @id @default(autoincrement())

  studentId Int
  bookId    Int

  borrowDate DateTime  @default(now())
  returnDate DateTime?

  student Student @relation(fields: [studentId], references: [id])
  book    Book    @relation(fields: [bookId], references: [id])
}

enum UserRole {
  ADMIN
  PETUGAS
  STUDENT
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      UserRole
  studentId Int?
  student   Student? @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
}
